    Boon::ModuleRegistration {{PROJECT_NAME}}_RegisterModule(Boon::ModuleContext* context)
    {
        if (!context)
            return { false, nullptr };

        Boon::ServiceLocator::SetRegistry(context->ServiceRegistry);
        Boon::BClassRegistry::SetRegistry(context->BClasses);
        Boon::NetRepRegistry::SetRegistry(context->NetReps);

{{REGISTER_REFLECTION_CALL}}

        Boon::ModuleInstance* instance = CreateModuleInstance();

        if (instance)
        {
            if (!instance->OnInitialize(*context))
            {
                DestroyModuleInstance(instance);
                return { false, nullptr };
            }
        }

        return { true, instance };
    }

    void {{PROJECT_NAME}}_UnregisterModule(
        Boon::ModuleContext* context,
        Boon::ModuleInstance* instance)
    {
        if (!context)
            return;

        if (instance)
        {
            instance->OnShutdown(*context);
            DestroyModuleInstance(instance);
        }

{{UNREGISTER_REFLECTION_CALL}}

        Boon::ServiceLocator::SetRegistry(nullptr);
        Boon::BClassRegistry::SetRegistry(nullptr);
        Boon::NetRepRegistry::SetRegistry(nullptr);
    }
}

