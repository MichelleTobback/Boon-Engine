// Automatically generated by BoonBuild. Do not modify.
#include "Module/StaticModules.h"
#include "Module/ModuleInstance.h"

#include <vector>

namespace Boon
{
    struct StaticLoadedModule
    {
        const ModuleInfo* Info = nullptr;
        ModuleInstance* Instance = nullptr;
        void (*UnregisterFn)(ModuleContext*, ModuleInstance*) = nullptr;
    };

    static std::vector<StaticLoadedModule> s_StaticModules;
}

extern "C"
{
{{PROJECT_STATIC_MODULE_DECLARATIONS}}
}

namespace Boon
{
    bool RegisterStaticModules(ModuleContext& context)
    {
        bool result = true;

{{PROJECT_STATIC_MODULE_REGISTER_CALLS}}

        return result;
    }

    void StartStaticModules(ModuleContext& context)
    {
        for (StaticLoadedModule& module : s_StaticModules)
        {
            if (module.Instance)
                module.Instance->OnStart(context);
        }
    }

    void StopStaticModules(ModuleContext& context)
    {
        for (auto it = s_StaticModules.rbegin(); it != s_StaticModules.rend(); ++it)
        {
            if (it->Instance)
                it->Instance->OnStop(context);
        }
    }

    void UnregisterStaticModules(ModuleContext& context)
    {
        for (auto it = s_StaticModules.rbegin(); it != s_StaticModules.rend(); ++it)
        {
            if (it->UnregisterFn)
                it->UnregisterFn(&context, it->Instance);
        }

        s_StaticModules.clear();
    }
}
