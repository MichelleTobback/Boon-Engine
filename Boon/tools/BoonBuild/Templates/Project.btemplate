@@generated/CMakeLists.txt
# Automatically generated by BoonBuild. Do not modify.

set(GAME_TARGET "{{PROJECT_NAME}}")

set(GAME_SOURCE_DIR
    "${CMAKE_CURRENT_LIST_DIR}/.."
)

set(GAME_GENERATED_DIR
    "${CMAKE_CURRENT_LIST_DIR}"
)

set(GAME_GENERATED_COMPONENTS_CPP
    "${GAME_GENERATED_DIR}/Generated_Components.cpp"
)

set(GAME_GENERATED_MODULE_CPP
    "${GAME_GENERATED_DIR}/Generated_Module.cpp"
)

include("${GAME_GENERATED_DIR}/EngineModules.cmake")

{{REFLECTION_BLOCK}}

file(GLOB_RECURSE GAME_SOURCES CONFIGURE_DEPENDS
    "${GAME_SOURCE_DIR}/src/*.cpp"
)

file(GLOB_RECURSE GAME_HEADERS CONFIGURE_DEPENDS
    "${GAME_SOURCE_DIR}/include/*.h"
    "${GAME_SOURCE_DIR}/include/*.hpp"
)

if(EXISTS "${GAME_SOURCE_DIR}/modules/generated/CMakeLists.txt")
    add_subdirectory(
        "${GAME_SOURCE_DIR}/modules/generated"
        "${CMAKE_BINARY_DIR}/${GAME_TARGET}_Modules"
    )
endif()

#
# Library type
#
if(NOT DEFINED BOON_BUILD_GAME_SHARED)
    set(BOON_BUILD_GAME_SHARED ON)
endif()

if(BOON_BUILD_GAME_SHARED)
    set(GAME_OUTPUT_TYPE SHARED)
else()
    set(GAME_OUTPUT_TYPE STATIC)
endif()

message(STATUS
    "Game module ${GAME_TARGET} output type: ${GAME_OUTPUT_TYPE}"
)

add_library(${GAME_TARGET} ${GAME_OUTPUT_TYPE}
    ${GAME_SOURCES}
    ${GAME_HEADERS}
    ${GAME_GENERATED_COMPONENTS_CPP}
    ${GAME_GENERATED_MODULE_CPP}
)

{{REFLECTION_DEPENDENCY_BLOCK}}

target_compile_features(${GAME_TARGET} PUBLIC cxx_std_20)

{{COMPILE_DEFINITIONS_BLOCK}}

if(BOON_BUILD_GAME_SHARED)
    target_compile_definitions(${GAME_TARGET}
        PRIVATE
            BOON_BUILD_GAME_SHARED
            ${GAME_TARGET}_EXPORTS
    )
endif()

{{INCLUDE_DIRECTORIES_BLOCK}}

{{LINK_LIBRARIES_BLOCK}}

boon_set_output_dirs(${GAME_TARGET} {{PROJECT_NAME}})

{{ASSET_COPY_BLOCK}}

